<?xml version="1.0" encoding="UTF-8"?>
<form>
  <config>
    <inlinehelp button="show"/>
  </config>
  <fieldset>
    <field
        name="id"
        type="number"
        label="JGLOBAL_FIELD_ID_LABEL"
        default="0"
        readonly="true"
        class="readonly"
    />
    <field
        addruleprefix="Weather\Component\WeatherOpenData\Administrator\Rule"
        name="name"
        type="text"
        label="COM_WEATHEROPENDATA_PRODUCT_NAME_LABEL"
        description="COM_WEATHEROPENDATA_PRODUCT_NAME_DESCRIPTION"
        required="true"
        maxlength="100"
        validate="name"
        message="COM_WEATHEROPENDATA_PRODUCT_NAME_ERROR"
    />
    <field
        name="protocol"
        type="radio"
        default="ftp"
        label="COM_WEATHEROPENDATA_PRODUCT_PROTOCOL_LABEL"
        description="COM_WEATHEROPENDATA_PRODUCT_PROTOCOL_DESCRIPTION"
    >
      <option value="ftp">ftp</option>
      <option value="http">http</option>
      <option value="https">https</option>
    </field>
    <field
        name="file"
        type="text"
        label="COM_WEATHEROPENDATA_PRODUCT_FILE_LABEL"
        description="COM_WEATHEROPENDATA_PRODUCT_FILE_DESCRIPTION"
        maxlength="250"
        required="true"
    />
    <field
        name="product"
        type="list"
        size="1"
        default="img"
        label="COM_WEATHEROPENDATA_PRODUCT_PRODUCT_LABEL"
        description="COM_WEATHEROPENDATA_PRODUCT_PRODUCT_DESCRIPTION"
    >
      <option value="img">COM_WEATHEROPENDATA_PRODUCT_FORMAT_IMG</option>
      <option value="txt">COM_WEATHEROPENDATA_PRODUCT_FORMAT_TXT</option>
      <option value="wmo">COM_WEATHEROPENDATA_PRODUCT_FORMAT_WMO</option>
      <option value="wmo_txt">COM_WEATHEROPENDATA_PRODUCT_FORMAT_WMO_TXT</option>
      <option value="html">COM_WEATHEROPENDATA_PRODUCT_FORMAT_HTML</option>
      <option value="fp13">COM_WEATHEROPENDATA_PRODUCT_FORMAT_FP13</option>
      <option value="fp13_title">COM_WEATHEROPENDATA_PRODUCT_FORMAT_FP13_TITLE</option>
      <option value="sx31">COM_WEATHEROPENDATA_PRODUCT_FORMAT_SX31</option>
      <option value="sx33">COM_WEATHEROPENDATA_PRODUCT_FORMAT_SX33</option>
      <option value="vhdl50_title">COM_WEATHEROPENDATA_PRODUCT_FORMAT_VHDL50_TITLE</option>
      <option value="vhdl">COM_WEATHEROPENDATA_PRODUCT_FORMAT_VHDL</option>
    </field>
    <field
        addruleprefix="Weather\Component\WeatherOpenData\Administrator\Rule"
        name="cache_minutes"
        type="text"
        label="COM_WEATHEROPENDATA_PRODUCT_CACHE_LABEL"
        description="COM_WEATHEROPENDATA_PRODUCT_CACHE_DESCRIPTION"
        maxlength="5"
        class="inputbox validate-numeric"
        data-validation-text="Numerische Eingabe erforderlich."
        pattern="^[0-9]+$"
        validate="cache"
        message="COM_WEATHEROPENDATA_PRODUCT_CACHE_VALIDATION"
        required="true"
        default="5"
    />
  </fieldset>
</form>
