<?xml version="1.0" encoding="utf-8"?>
<config>
  <inlinehelp button="show"/>
  <fieldset
      name="products"
      label="COM_WEATHEROPENDATA_SETTINGS_LABEL"
      description="COM_WEATHEROPENDATA_SETTINGS_DESCRIPTION">
    <field
        name="opendata_username"
        type="text"
        required="true"
        label="COM_WEATHEROPENDATA_SETTINGS_USERNAME_LABEL"
        description="COM_WEATHEROPENDATA_SETTINGS_USERNAME_DESCRIPTION"
        default="anonymous"/>
    <field
        name="opendata_password"
        type="password"
        required="true"
        label="COM_WEATHEROPENDATA_SETTINGS_PASSWORD_LABEL"
        description="COM_WEATHEROPENDATA_SETTINGS_PASSWORD_DESCRIPTION"
        default="anonymous"/>
    <field
        name="opendata_host"
        type="text"
        required="true"
        label="COM_WEATHEROPENDATA_SETTINGS_HOST_LABEL"
        description="COM_WEATHEROPENDATA_SETTINGS_HOST_DESCRIPTION"
        default="opendata.dwd.de"/>
    <field
        name="opendata_passive"
        type="radio"
        layout="joomla.form.field.radio.switcher"
        label="COM_WEATHEROPENDATA_SETTINGS_FTPMODE_LABEL"
        description="COM_WEATHEROPENDATA_SETTINGS_FTPMODE_DESCRIPTION"
        default="1">
      <option value="0">JDISABLED</option>
      <option value="1">JENABLED</option>
    </field>
  </fieldset>
</config>
