<?xml version="1.0" encoding="utf-8"?>
<config>
  <inlinehelp button="show"/>
  <fieldset
      name="products"
      label="COM_WEATHEROPENDATA_SETTINGS_LABEL"
      description="COM_WEATHEROPENDATA_SETTINGS_DESCRIPTION">
    <field
        name="opendata_username"
        type="text"
        required="true"
        label="COM_WEATHEROPENDATA_SETTINGS_USERNAME_LABEL"
        description="COM_WEATHEROPENDATA_SETTINGS_USERNAME_DESCRIPTION"
        default="anonymous"/>
    <field
        name="opendata_password"
        type="password"
        required="true"
        label="COM_WEATHEROPENDATA_SETTINGS_PASSWORD_LABEL"
        description="COM_WEATHEROPENDATA_SETTINGS_PASSWORD_DESCRIPTION"
        default="anonymous"/>
    <field
        name="opendata_host"
        type="text"
        required="true"
        label="COM_WEATHEROPENDATA_SETTINGS_HOST_LABEL"
        description="COM_WEATHEROPENDATA_SETTINGS_HOST_DESCRIPTION"
        default="opendata.dwd.de"/>
    <field
        name="opendata_passive"
        type="radio"
        layout="joomla.form.field.radio.switcher"
        label="COM_WEATHEROPENDATA_SETTINGS_FTPMODE_LABEL"
        description="COM_WEATHEROPENDATA_SETTINGS_FTPMODE_DESCRIPTION"
        default="1">
      <option value="0">JDISABLED</option>
      <option value="1">JENABLED</option>
    </field>
  </fieldset>
  <fieldset
      name="charts"
      label="COM_WEATHEROPENDATA_CHARTS_SETTINGS_LABEL"
      description="COM_WEATHEROPENDATA_CHARTS_SETTINGS_DESCRIPTION">
    <field
        name="datapath"
        type="text"
        label="COM_WEATHEROPENDATA_CHARTS_SETTINGS_DATAPATH_LABEL"
        description="COM_WEATHEROPENDATA_CHARTS_SETTINGS_DATAPATH_DESCRIPTION"
        maxlength="100"
        required="true"
        default="./media/com_weatheropendata/chart/json"
    />
    <field
        name="themeVersion"
        type="text"
        maxlength="5"
        default="1"
        class="inputbox validate-numeric"
        data-validation-text="Numerische Eingabe erforderlich."
        pattern="^[0-9]+$"
        label="COM_WEATHEROPENDATA_CHARTS_SETTINGS_THEMEVERSION_LABEL"
        description="COM_WEATHEROPENDATA_CHARTS_SETTINGS_THEMEVERSION_DESCRIPTION"/>
  </fieldset>
  <fieldset name="insertcontent"
            label="COM_WEATHEROPENDATA_INSERTCONTENT_SETTINGS_LABEL"
            description="COM_WEATHEROPENDATA_INSERTCONTENT_SETTINGS_DESCRIPTION">
    <field
        name="insertcontentDataPath"
        type="text"
        size="50"
        default="../Daten"
        label="COM_WEATHEROPENDATA_INSERTCONTENT_SETTINGS_DIR_LABEL"
        description="COM_WEATHEROPENDATA_INSERTCONTENT_SETTINGS_DIR_DESCRIPTION"/>
  </fieldset>
</config>
